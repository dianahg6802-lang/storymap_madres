/* CONSTELACIÓN */
(function(){
  const canvas=document.getElementById('constellation-canvas'),ctx=canvas.getContext('2d'),tooltip=document.getElementById('star-tooltip');
  const words=['amor','guía','hogar','fuerza','ternura','apoyo','abrazo','vida','fe','luz','calma','raíces','cobijo','alegría','magia'];
  const stars=[];let W,H,mouseX=-999,mouseY=-999;
  function resize(){const rect=canvas.getBoundingClientRect();W=canvas.width=rect.width;H=canvas.height=rect.height;buildStars();}
  function buildStars(){stars.length=0;const N=Math.min(55,Math.floor(W*H/3500));for(let i=0;i<N;i++){stars.push({x:20+Math.random()*(W-40),y:20+Math.random()*(H-40),r:1.2+Math.random()*2.8,pulse:Math.random()*Math.PI*2,speed:0.02+Math.random()*0.03,word:words[i%words.length],brightness:0.5+Math.random()*0.5,hovered:false});}stars.forEach(s=>{s.links=stars.filter(o=>o!==s&&Math.hypot(o.x-s.x,o.y-s.y)<120).slice(0,3);});}
  function draw(){ctx.clearRect(0,0,W,H);stars.forEach(s=>{s.links.forEach(o=>{const d=Math.hypot(s.x-o.x,s.y-o.y);ctx.beginPath();ctx.moveTo(s.x,s.y);ctx.lineTo(o.x,o.y);ctx.strokeStyle=`rgba(242,196,206,${0.15*(1-d/130)})`;ctx.lineWidth=0.6;ctx.stroke();});});
  stars.forEach(s=>{s.pulse+=s.speed;const pf=0.7+0.3*Math.sin(s.pulse),hovD=Math.hypot(s.x-mouseX,s.y-mouseY);s.hovered=hovD<28;const r=s.r*pf*(s.hovered?2.2:1),glow=ctx.createRadialGradient(s.x,s.y,0,s.x,s.y,r*5),alph=s.brightness*pf;
  if(s.hovered){glow.addColorStop(0,'rgba(255,220,235,1)');glow.addColorStop(0.3,'rgba(242,196,206,0.7)');glow.addColorStop(1,'rgba(232,213,240,0)');}else{glow.addColorStop(0,`rgba(255,240,248,${alph})`);glow.addColorStop(0.4,`rgba(242,196,206,${alph*0.4})`);glow.addColorStop(1,'rgba(232,213,240,0)');}
  ctx.beginPath();ctx.arc(s.x,s.y,r*4,0,Math.PI*2);ctx.fillStyle=glow;ctx.fill();ctx.beginPath();ctx.arc(s.x,s.y,r,0,Math.PI*2);ctx.fillStyle=s.hovered?'rgba(255,230,240,1)':`rgba(255,240,248,${alph})`;ctx.fill();});requestAnimationFrame(draw);}
  canvas.addEventListener('mousemove',e=>{const rect=canvas.getBoundingClientRect();mouseX=e.clientX-rect.left;mouseY=e.clientY-rect.top;const hov=stars.find(s=>Math.hypot(s.x-mouseX,s.y-mouseY)<28);if(hov){tooltip.textContent=hov.word;tooltip.style.left=(e.clientX+16)+'px';tooltip.style.top=(e.clientY-12)+'px';tooltip.classList.add('show');}else tooltip.classList.remove('show');});
  canvas.addEventListener('mouseleave',()=>{mouseX=-999;mouseY=-999;tooltip.classList.remove('show');});
  canvas.addEventListener('touchmove',e=>{e.preventDefault();const t=e.touches[0],rect=canvas.getBoundingClientRect();mouseX=t.clientX-rect.left;mouseY=t.clientY-rect.top;},{passive:false});
  window.addEventListener('resize',resize);resize();requestAnimationFrame(draw);
})();

