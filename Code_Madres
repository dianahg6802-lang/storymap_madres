    {petals:5,petalColor:'#fde8b0',centerColor:'#f2c4ce',rx:13,ry:7,orbit:17,phrase:'"Semilla de amor eterno."'},
    {petals:6,petalColor:'#c9e8d5',centerColor:'#f7d9c4',rx:12,ry:6,orbit:16,phrase:'"Raíces que me dan alas."'},
