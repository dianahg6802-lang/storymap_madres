    return`<svg viewBox="-${size/2} -${size/2} ${size} ${size}" xmlns="http://www.w3.org/2000/svg" width="${size}" height="${size}"><g>${pEls}</g><circle r="${ry*0.9}" fill="${cc}"/></svg>`;
  }
