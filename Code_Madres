<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Cartografía del Amor para Mamá 💐</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&family=Crimson+Pro:ital,wght@0,300;0,400;1,300;1,400&family=Great+Vibes&family=Tenor+Sans&display=swap" rel="stylesheet" />
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --rose:#f2c4ce;--rose-deep:#c4687e;--rose-soft:#fce8ed;
  --peach:#f7d9c4;--peach-mid:#e8a882;--cream:#fdf7f0;
  --lavender:#e8d5f0;--lav-soft:#f5eeff;--lav-deep:#9b72b8;
  --gold:#c9a96e;--gold-light:#f0e2c4;--white:#fffcfa;
  --ink:#3d2535;--ink-soft:#6b4a58;
  --shadow-warm:rgba(196,104,126,0.15);--shadow-deep:rgba(61,37,53,0.12);
}
html { scroll-behavior: smooth; }
body { font-family:'Crimson Pro',Georgia,serif; background:var(--cream); color:var(--ink); overflow-x:hidden; cursor:default; }
#particle-canvas { position:fixed; inset:0; pointer-events:none; z-index:0; }

/* HERO */
.hero { position:relative; min-height:100vh; display:flex; flex-direction:column; align-items:center; justify-content:center; text-align:center; overflow:hidden;
  background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(242,196,206,0.55) 0%, transparent 70%),
    radial-gradient(ellipse 60% 50% at 80% 80%, rgba(232,213,240,0.5) 0%, transparent 70%),
    radial-gradient(ellipse 50% 40% at 10% 70%, rgba(247,217,196,0.45) 0%, transparent 70%),
    linear-gradient(170deg,#fdf7f0 0%,#fce8ed 40%,#f5eeff 70%,#fdf0e8 100%);
  z-index:1; }
.hero-flowers { position:absolute; inset:0; pointer-events:none; overflow:hidden; }
.hero-flower { position:absolute; opacity:0; animation:heroFlowerFloat var(--dur,12s) ease-in-out var(--del,0s) infinite; }
@keyframes heroFlowerFloat {
  0%   { opacity:0; transform:translateY(20px) rotate(var(--r0,0deg)) scale(0.8); }
  15%  { opacity:var(--op,0.55); }
  50%  { transform:translateY(-18px) rotate(var(--r1,15deg)) scale(1); }
  85%  { opacity:var(--op,0.55); }
  100% { opacity:0; transform:translateY(20px) rotate(var(--r0,0deg)) scale(0.8); }
}
.petal-fall { position:absolute; pointer-events:none; font-size:var(--sz,1.2rem); animation:petalDrift var(--dur,10s) linear var(--del,0s) infinite; top:-60px; left:var(--x,50%); opacity:0; }
@keyframes petalDrift {
  0%   { transform:translateY(0) rotate(0deg) translateX(0); opacity:0; }
  8%   { opacity:0.7; }
  92%  { opacity:0.5; }
  100% { transform:translateY(105vh) rotate(540deg) translateX(var(--dx,40px)); opacity:0; }
}
.hero-content { position:relative; z-index:2; padding:2rem 1.5rem; animation:heroReveal 2s cubic-bezier(0.16,1,0.3,1) both; }
@keyframes heroReveal { from{opacity:0;transform:translateY(40px)} to{opacity:1;transform:translateY(0)} }
.hero-pre { font-family:'Great Vibes',cursive; font-size:clamp(1.4rem,4vw,2rem); color:var(--peach-mid); letter-spacing:0.05em; margin-bottom:0.3rem; animation:heroReveal 2s 0.3s cubic-bezier(0.16,1,0.3,1) both; }
.hero h1 { font-family:'Cormorant Garamond',serif; font-weight:300; font-size:clamp(2.2rem,7vw,4.5rem); line-height:1.12; color:var(--ink); text-shadow:0 2px 40px rgba(196,104,126,0.2); letter-spacing:-0.01em; animation:heroReveal 2s 0.5s cubic-bezier(0.16,1,0.3,1) both; }
.hero h1 em { font-style:italic; color:var(--rose-deep); }
.hero-sub { font-family:'Crimson Pro',serif; font-size:clamp(1rem,2.8vw,1.3rem); font-weight:300; font-style:italic; color:var(--ink-soft); max-width:540px; margin:1.2rem auto 0; line-height:1.7; animation:heroReveal 2s 0.8s cubic-bezier(0.16,1,0.3,1) both; }
.hero-scroll-hint { position:absolute; bottom:2.5rem; left:50%; transform:translateX(-50%); display:flex; flex-direction:column; align-items:center; gap:0.4rem; color:var(--ink-soft); font-size:0.78rem; letter-spacing:0.12em; text-transform:uppercase; font-family:'Tenor Sans',sans-serif; opacity:0.6; animation:heroReveal 2s 1.5s both, scrollBounce 2s 2s ease-in-out infinite; }
@keyframes scrollBounce { 0%,100%{transform:translateX(-50%) translateY(0)} 50%{transform:translateX(-50%) translateY(6px)} }

/* GENERAL */
.section { position:relative; z-index:1; padding:5rem 1.5rem; }
.section-inner { max-width:900px; margin:0 auto; }
.section-label { font-family:'Tenor Sans',sans-serif; font-size:0.72rem; letter-spacing:0.22em; text-transform:uppercase; color:var(--peach-mid); margin-bottom:0.5rem; display:block; }
.section-title { font-family:'Cormorant Garamond',serif; font-weight:300; font-size:clamp(1.8rem,5vw,2.8rem); color:var(--ink); line-height:1.2; margin-bottom:0.5rem; }
.section-title em { font-style:italic; color:var(--rose-deep); }
.section-desc { font-size:clamp(0.95rem,2.2vw,1.1rem); color:var(--ink-soft); font-style:italic; max-width:520px; line-height:1.7; }
.deco-line { width:60px; height:1px; background:linear-gradient(90deg,transparent,var(--rose),transparent); margin:1.4rem 0; }
.fade-reveal { opacity:0; transform:translateY(32px); transition:opacity 0.9s cubic-bezier(0.16,1,0.3,1),transform 0.9s cubic-bezier(0.16,1,0.3,1); }
.fade-reveal.visible { opacity:1; transform:translateY(0); }
.fade-reveal.delay-1{transition-delay:0.1s}.fade-reveal.delay-2{transition-delay:0.22s}.fade-reveal.delay-3{transition-delay:0.36s}.fade-reveal.delay-4{transition-delay:0.5s}.fade-reveal.delay-5{transition-delay:0.65s}

/* SECCIÓN REGALOS */
.gifts-section {
  background: radial-gradient(ellipse 80% 50% at 20% 50%, rgba(247,217,196,0.3) 0%, transparent 70%),
    linear-gradient(160deg,#fdf7f0 0%,#fce8ed 60%,#fdf7f0 100%);
}
.gifts-grid {
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(220px,1fr));
  gap:1.6rem;
  margin-top:2.8rem;
}
.gift-card {
  background:var(--white);
  border-radius:18px;
  padding:1.6rem 1.4rem 1.4rem;
  box-shadow:0 6px 28px var(--shadow-warm),0 1px 6px var(--shadow-deep),inset 0 0 0 1px rgba(255,255,255,0.8);
  display:flex;
  flex-direction:column;
  gap:0.6rem;
  transition:transform 0.4s cubic-bezier(0.34,1.56,0.64,1),box-shadow 0.4s;
  cursor:default;
  position:relative;
}
.gift-card:hover {
  transform:translateY(-8px) scale(1.03);
  box-shadow:0 18px 50px var(--shadow-warm),0 4px 16px var(--shadow-deep);
  z-index:10;
}
.gift-emoji { font-size:2.4rem; line-height:1; }
.gift-title { font-family:'Cormorant Garamond',serif; font-weight:600; font-size:1.05rem; color:var(--ink); }
.gift-desc { font-family:'Crimson Pro',serif; font-size:0.88rem; font-style:italic; color:var(--ink-soft); line-height:1.55; }
.gift-tag { display:inline-block; font-family:'Tenor Sans',sans-serif; font-size:0.62rem; letter-spacing:0.12em; text-transform:uppercase; color:var(--rose-deep); background:var(--rose-soft); border-radius:50px; padding:0.2rem 0.7rem; margin-top:0.2rem; align-self:flex-start; }

/* CONSTELACIÓN */
.constellation-section { background:linear-gradient(180deg,#1a0d14 0%,#2d1525 50%,#1a0d14 100%); color:rgba(255,235,245,0.9); overflow:hidden; min-height:600px; display:flex; flex-direction:column; align-items:center; justify-content:flex-start; padding:5rem 1.5rem; }
.constellation-section .section-label{color:var(--peach)}
.constellation-section .section-title{color:rgba(255,235,245,0.95)}
.constellation-section .section-desc{color:rgba(255,200,220,0.7)}
#constellation-canvas { width:100%; max-width:820px; height:420px; border-radius:16px; margin-top:2.5rem; cursor:crosshair; }
.star-tooltip { position:fixed; pointer-events:none; background:rgba(30,10,20,0.85); border:1px solid rgba(242,196,206,0.3); border-radius:50px; padding:0.4rem 1rem; font-family:'Cormorant Garamond',serif; font-style:italic; font-size:1.1rem; color:var(--rose-soft); opacity:0; transition:opacity 0.3s; z-index:100; white-space:nowrap; backdrop-filter:blur(6px); }
.star-tooltip.show{opacity:1}

/* NUBE */
.wordcloud-section { background:radial-gradient(ellipse 60% 60% at 50% 50%,rgba(232,213,240,0.4) 0%,transparent 80%),linear-gradient(135deg,#fdf7f0 0%,#f5eeff 50%,#fce8ed 100%); text-align:center; }
.word-cloud { display:flex; flex-wrap:wrap; justify-content:center; align-items:center; gap:0.6rem 1rem; max-width:720px; margin:2.5rem auto 0; padding:1.5rem; }
.wc-word { font-family:'Cormorant Garamond',serif; font-style:italic; color:var(--c,var(--ink-soft)); font-size:var(--sz,1.2rem); opacity:var(--op,0.8); cursor:default; padding:0.2rem 0.5rem; border-radius:4px; transition:transform 0.35s cubic-bezier(0.34,1.56,0.64,1),opacity 0.3s; animation:wordFloat var(--dur,5s) ease-in-out var(--del,0s) infinite; animation-direction:alternate; }
.wc-word:hover{transform:scale(1.25) translateY(-5px);opacity:1!important}
@keyframes wordFloat{from{transform:translateY(0px) rotate(var(--r,0deg))}to{transform:translateY(var(--ty,-8px)) rotate(var(--r2,0deg))}}

/* FLORES */
.flowers-section { background:linear-gradient(170deg,#fdf7f0 0%,#fce8f0 60%,#f5f0ff 100%); overflow:hidden; }
.flowers-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(160px,1fr)); gap:2rem; margin-top:2.5rem; }
.flower-item { display:flex; flex-direction:column; align-items:center; gap:0.8rem; cursor:default; position:relative; }
.flower-svg-wrap { width:110px; height:110px; display:flex; align-items:center; justify-content:center; animation:flowerFloat var(--dur,5s) ease-in-out var(--del,0s) infinite; transition:transform 0.4s cubic-bezier(0.34,1.56,0.64,1); filter:drop-shadow(0 8px 20px var(--shadow-warm)); }
@keyframes flowerFloat{0%,100%{transform:translateY(0) rotate(var(--r0,-2deg))}50%{transform:translateY(-12px) rotate(var(--r1,2deg))}}
.flower-item:hover .flower-svg-wrap{transform:scale(1.15) translateY(-8px)}
.flower-phrase { font-family:'Crimson Pro',serif; font-size:0.88rem; font-style:italic; color:var(--ink-soft); text-align:center; line-height:1.5; max-width:130px; opacity:0; transform:translateY(6px); transition:opacity 0.35s,transform 0.35s; }
.flower-item:hover .flower-phrase{opacity:1;transform:translateY(0)}

/* TIMELINE */
.timeline-section { background:radial-gradient(ellipse 70% 50% at 30% 50%,rgba(247,217,196,0.35) 0%,transparent 70%),linear-gradient(160deg,#fdf7f0 0%,#fff5f8 100%); }
.timeline { position:relative; margin-top:3rem; padding-left:0; }
.timeline::before { content:''; position:absolute; left:50%; top:0; bottom:0; width:1px; background:linear-gradient(180deg,transparent 0%,var(--rose) 15%,var(--rose) 85%,transparent 100%); transform:translateX(-50%); }
.timeline-item { display:flex; width:100%; margin-bottom:3rem; position:relative; }
.timeline-item:nth-child(odd){flex-direction:row-reverse}
.timeline-item:nth-child(odd) .timeline-content{margin-right:calc(50% + 2rem);margin-left:0;text-align:right}
.timeline-item:nth-child(even) .timeline-content{margin-left:calc(50% + 2rem)}
.timeline-dot { position:absolute; left:50%; top:0.6rem; transform:translateX(-50%); width:14px; height:14px; border-radius:50%; background:var(--rose); border:3px solid var(--white); box-shadow:0 0 0 2px var(--rose),0 4px 12px var(--shadow-warm); z-index:2; transition:transform 0.3s,box-shadow 0.3s; }
.timeline-item:hover .timeline-dot{transform:translateX(-50%) scale(1.4);box-shadow:0 0 0 3px var(--rose),0 6px 20px var(--shadow-warm)}
.timeline-content { max-width:42%; background:var(--white); border-radius:14px; padding:1.2rem 1.4rem; box-shadow:0 4px 24px var(--shadow-warm),0 1px 6px var(--shadow-deep); border:1px solid rgba(242,196,206,0.4); transition:transform 0.35s cubic-bezier(0.34,1.56,0.64,1); }
.timeline-item:hover .timeline-content{transform:translateY(-4px)}
.timeline-emoji{font-size:1.5rem;margin-bottom:0.3rem;display:block}
.timeline-label{font-family:'Tenor Sans',sans-serif;font-size:0.65rem;letter-spacing:0.15em;text-transform:uppercase;color:var(--peach-mid);margin-bottom:0.2rem}
.timeline-title{font-family:'Cormorant Garamond',serif;font-size:1.1rem;font-weight:600;color:var(--ink);margin-bottom:0.3rem}
.timeline-text{font-family:'Crimson Pro',serif;font-size:0.92rem;font-style:italic;color:var(--ink-soft);line-height:1.6}
@media(max-width:600px){
  .timeline::before{left:20px}.timeline-dot{left:20px}
  .timeline-item,.timeline-item:nth-child(odd){flex-direction:column}
  .timeline-content,.timeline-item:nth-child(odd) .timeline-content,.timeline-item:nth-child(even) .timeline-content{max-width:100%;margin-left:48px;margin-right:0;text-align:left}
}

/* FOOTER */
.footer-section { background:linear-gradient(170deg,#2d1525 0%,#1a0d14 100%); text-align:center; color:rgba(255,220,235,0.85); padding:5rem 1.5rem 4rem; position:relative; overflow:hidden; }
.footer-section::before { content:''; position:absolute; inset:0; background:radial-gradient(ellipse 60% 50% at 50% 0%,rgba(196,104,126,0.25) 0%,transparent 70%); }
.footer-quote { font-family:'Great Vibes',cursive; font-size:clamp(2rem,6vw,3.2rem); color:rgba(255,200,218,0.9); line-height:1.3; max-width:600px; margin:0 auto 1.4rem; position:relative; z-index:1; }
.footer-attr { font-family:'Tenor Sans',sans-serif; font-size:0.75rem; letter-spacing:0.18em; text-transform:uppercase; color:rgba(255,180,200,0.5); position:relative; z-index:1; }
@media(max-width:540px){.section{padding:3.5rem 1rem}.flowers-grid{grid-template-columns:repeat(auto-fill,minmax(130px,1fr))}#constellation-canvas{height:320px}}
</style>
</head>
<body>

<canvas id="particle-canvas"></canvas>
<div class="star-tooltip" id="star-tooltip"></div>

<!-- HERO -->
<section class="hero" id="hero">
  <div class="hero-flowers" id="hero-flowers" aria-hidden="true"></div>
  <div id="petals-wrap" aria-hidden="true"></div>
  <div class="hero-content">
    <p class="hero-pre">con todo el amor del mundo…</p>
    <h1>Cartografía del<br><em>Amor para Mamá</em> 💐</h1>
    <p class="hero-sub">Cada punto del mapa guarda una historia, un recuerdo y unas palabras para mamá.</p>
  </div>
  <div class="hero-scroll-hint" aria-hidden="true">
    <svg width="18" height="28" viewBox="0 0 18 28" fill="none"><rect x="1" y="1" width="16" height="22" rx="8" stroke="currentColor" stroke-width="1.2"/><circle cx="9" cy="7" r="2" fill="currentColor" opacity="0.7"><animateTransform attributeName="transform" type="translate" values="0,0;0,8;0,0" dur="1.8s" repeatCount="indefinite"/></circle></svg>
    Descende
  </div>
</section>

<!-- SECCIÓN REGALOS -->
<section class="section gifts-section" id="gifts">
  <div class="section-inner">
    <span class="section-label fade-reveal">Ideas con amor</span>
    <h2 class="section-title fade-reveal delay-1"><em>Regalos</em> para mamá</h2>
    <p class="section-desc fade-reveal delay-2">Detalles que dicen lo que a veces las palabras no alcanzan. Porque ella lo merece todo.</p>
    <div class="deco-line fade-reveal delay-2"></div>
    <div class="gifts-grid" id="gifts-grid"></div>
  </div>
</section>

<!-- CONSTELACIÓN -->
<section class="section constellation-section" id="constellation">
  <div class="section-inner" style="width:100%;max-width:820px;margin:0 auto;text-align:center;">
    <span class="section-label fade-reveal">Universo de amor</span>
    <h2 class="section-title fade-reveal delay-1">Constelación de <em>Mamás</em> ✨</h2>
    <p class="section-desc fade-reveal delay-2" style="margin:0 auto;">Cada estrella es un amor único. Pasa el cursor y descubre la palabra que la define.</p>
    <canvas id="constellation-canvas" class="fade-reveal delay-3" aria-label="Cielo estrellado interactivo con palabras sobre mamá"></canvas>
  </div>
</section>

<!-- NUBE -->
<section class="section wordcloud-section" id="wordcloud">
  <div class="section-inner" style="text-align:center;">
    <span class="section-label fade-reveal">Jardín de palabras</span>
    <h2 class="section-title fade-reveal delay-1"><em>Las palabras</em> que la describen</h2>
    <p class="section-desc fade-reveal delay-2" style="margin:0 auto;">Un jardín de palabras que florecen solo para ella.</p>
    <div class="word-cloud fade-reveal delay-3" id="word-cloud"></div>
  </div>
</section>

<!-- FLORES -->
<section class="section flowers-section" id="flowers">
  <div class="section-inner">
    <span class="section-label fade-reveal">Jardín emocional</span>
    <h2 class="section-title fade-reveal delay-1"><em>Galería</em> de Flores</h2>
    <p class="section-desc fade-reveal delay-2">Como las flores, el amor de mamá nunca se marchita. Toca cada una y déjate llevar.</p>
    <div class="deco-line fade-reveal delay-2"></div>
    <div class="flowers-grid" id="flowers-grid"></div>
  </div>
</section>

<!-- TIMELINE -->
<section class="section timeline-section" id="timeline">
  <div class="section-inner">
    <span class="section-label fade-reveal">Memoria del hogar</span>
    <h2 class="section-title fade-reveal delay-1">Momentos que<br><em>construyen un hogar</em></h2>
    <p class="section-desc fade-reveal delay-2">Los instantes que nos formaron, uno a uno, tejidos con amor.</p>
    <div class="deco-line fade-reveal delay-2"></div>
    <div class="timeline" id="timeline-el"></div>
  </div>
</section>

<!-- FOOTER -->
<footer class="footer-section">
  <p class="footer-quote fade-reveal">"Ser tu hijo o hija es el mayor privilegio de mi vida."</p>
  <p class="footer-attr fade-reveal delay-1">— Con amor, siempre 🌸</p>
</footer>

<script>
/* PARTÍCULAS */
(function(){
  const canvas=document.getElementById('particle-canvas'),ctx=canvas.getContext('2d');
  const COLS=['rgba(242,196,206,','rgba(232,213,240,','rgba(247,217,196,','rgba(255,240,250,'];
  const particles=[],COUNT=55;
  function resize(){canvas.width=window.innerWidth;canvas.height=document.documentElement.scrollHeight;}
  function newP(){return{x:Math.random()*canvas.width,y:Math.random()*canvas.height,r:1+Math.random()*3,vx:(Math.random()-0.5)*0.3,vy:-(0.15+Math.random()*0.3),a:Math.random(),va:0.003+Math.random()*0.005,col:COLS[Math.floor(Math.random()*COLS.length)]};}
  for(let i=0;i<COUNT;i++)particles.push(newP());
  function draw(){ctx.clearRect(0,0,canvas.width,canvas.height);for(const p of particles){ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,Math.PI*2);ctx.fillStyle=p.col+(0.15+p.a*0.5)+')';ctx.fill();p.x+=p.vx;p.y+=p.vy;p.a+=p.va;if(p.a>1||p.a<0)p.va*=-1;if(p.y<-10){p.y=canvas.height+10;p.x=Math.random()*canvas.width;}}requestAnimationFrame(draw);}
  window.addEventListener('resize',resize);resize();draw();
})();

/* PÉTALOS */
(function(){
  const wrap=document.getElementById('petals-wrap');
  const chars=['🌸','🌷','🌺','🌼','✿','❀','💮'];
  for(let i=0;i<18;i++){const el=document.createElement('div');el.className='petal-fall';el.textContent=chars[Math.floor(Math.random()*chars.length)];el.style.setProperty('--x',(5+Math.random()*90)+'%');el.style.setProperty('--dx',((Math.random()-0.5)*80)+'px');el.style.setProperty('--dur',(9+Math.random()*12)+'s');el.style.setProperty('--del',(Math.random()*14)+'s');el.style.setProperty('--sz',(0.9+Math.random()*1.2)+'rem');wrap.appendChild(el);}
})();

/* FLORES HERO */
(function(){
  const wrap=document.getElementById('hero-flowers');
  const flowerSVGs=[
    (c1,c2)=>`<svg viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg" width="80" height="80"><g transform="translate(40,40)">${[0,60,120,180,240,300].map(a=>`<ellipse cx="${Math.cos(a*Math.PI/180)*18}" cy="${Math.sin(a*Math.PI/180)*18}" rx="10" ry="7" fill="${c1}" transform="rotate(${a},${Math.cos(a*Math.PI/180)*18},${Math.sin(a*Math.PI/180)*18})" opacity="0.85"/>`).join('')}<circle cx="0" cy="0" r="9" fill="${c2}"/></g></svg>`,
    (c1,c2)=>`<svg viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg" width="80" height="80"><g transform="translate(40,40)">${[0,45,90,135,180,225,270,315].map(a=>`<ellipse cx="${Math.cos(a*Math.PI/180)*15}" cy="${Math.sin(a*Math.PI/180)*15}" rx="9" ry="5" fill="${c1}" opacity="0.8" transform="rotate(${a} ${Math.cos(a*Math.PI/180)*15} ${Math.sin(a*Math.PI/180)*15})"/>`).join('')}<circle r="8" fill="${c2}"/></g></svg>`,
